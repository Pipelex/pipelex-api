# ──────────────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────────────

# Pipelex Gateway API key — used by the API to call LLMs through Pipelex's
# unified inference layer. Get one at https://app.pipelex.com (free credits
# included).
#
# This is the only credential needed *if* you keep the default routing profile.
# If you switch the inference backend in your Pipelex config to use OpenAI,
# Anthropic, Azure, Bedrock, etc. directly, you'll need that backend's own env
# vars instead. See https://docs.pipelex.com for backend configuration.

PIPELEX_GATEWAY_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Authentication (optional — defaults to AUTH_MODE=none)
# ──────────────────────────────────────────────────────────────────────────────

# One of: none | api_key | jwt
# AUTH_MODE=none

# Used when AUTH_MODE=api_key. Clients pass: Authorization: Bearer <API_KEY>
# API_KEY=

# Used when AUTH_MODE=jwt. Tokens must be HS256 and contain an "email" claim.
# JWT_SECRET_KEY=

# When AUTH_MODE=none and the API sits behind a trusted reverse proxy that
# performs authentication and forwards identity via X-User-Email / X-User-Sub
# / X-User-Id / X-Auth-Method headers, set this to "true" to honor those
# headers. DEFAULT IS OFF: if you set this, you MUST ensure your proxy strips
# inbound copies of those headers before adding its own — otherwise any
# external client can spoof user identity by sending the headers themselves.
# TRUST_FORWARDED_IDENTITY_HEADERS=false

# ──────────────────────────────────────────────────────────────────────────────
# Uploader (optional — only relevant if you use POST /v1/upload)
# ──────────────────────────────────────────────────────────────────────────────

# Maximum decoded size, in MiB, accepted by the /upload endpoint. Defaults to
# 50. Raise it for larger documents/datasets, lower it to harden the server
# against memory exhaustion. Read once at startup — change requires a restart.
# MAX_UPLOAD_MIB=50

# ──────────────────────────────────────────────────────────────────────────────
# Pipelex environment selector (optional)
# ──────────────────────────────────────────────────────────────────────────────

# Selects which pipelex_{PIPELEX_ENV}.toml override file is layered on top of
# the baseline configuration. Defaults to "dev" when unset. See docs/configuration.md.
# PIPELEX_ENV=dev

# ──────────────────────────────────────────────────────────────────────────────
# Temporal (optional — only needed when [temporal] is_enabled = true in your config)
# ──────────────────────────────────────────────────────────────────────────────

# Pipelex's [temporal] config block can interpolate env vars via ${VAR}
# (e.g. `api_key = "${TEMPORAL_API_KEY}"`). This var has no effect on its own —
# it's only useful if your mounted `.pipelex/` config references it.
# TEMPORAL_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Bundle runner tooling (optional — used by `make bundle-*` / the
# postman-run-bundle skill, NOT read by the API server itself)
# ──────────────────────────────────────────────────────────────────────────────

# Default callback webhook for the async POST /v1/start endpoint.
# A `start` request is fire-and-forget: it returns a run_id immediately
# and POSTs the finished result to this URL later. The `make bundle-*` targets
# and the postman-run-bundle skill read this when building a `start` query
# (override per run with CALLBACK_URL=... or --callback-url). Must be a public
# http(s) URL — loopback/private/metadata hosts are rejected by the API's SSRF
# guard. A throwaway https://webhook.site/<id> endpoint is the easy way to watch
# results land.
# CALLBACK_URL=
